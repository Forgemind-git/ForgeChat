# ForgeChat backend configuration — copy to .env and fill in.
# NEVER commit your real .env. See CONTRIBUTING.md for local-dev setup.

# ── App ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────
# Password for the Postgres container (the db service in docker-compose reads
# this from the same file) AND the password component of DATABASE_URL below.
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change-this-to-a-strong-random-password
# Primary connection string (preferred). Use the same password as above.
DATABASE_URL=postgresql://postgres:change-this-to-a-strong-random-password@localhost:5432/postgres
POSTGRES_SSL=false
# Fallback discrete params (used only if DATABASE_URL is unset).
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_password

# ── Redis (required — BullMQ send + media-download queues) ──────────────
REDIS_URL=redis://localhost:6379

# ── Auth & encryption ──────────────────────────────────────────────────
# IMPORTANT: in production (NODE_ENV=production) the app REFUSES to start if
# these are blank, a known placeholder, or shorter than 32 chars. Generate real
# values — do not ship the example strings:  openssl rand -hex 32
# JWT secret — signs auth tokens.
JWT_SECRET=change-this-to-a-random-string
# Dedicated key for encrypting stored Meta access tokens (AES-256-GCM, SHA-256'd
# to a 32-byte key). Required in production; must differ from JWT_SECRET.
FORGECRM_ENCRYPTION_KEY=change-this-to-another-random-string

# First-run admin seed (only used when the users table is empty).
# If ADMIN_PASSWORD is unset, a random password is generated and printed once
# in the backend logs on first boot — set it explicitly for a known credential.
ADMIN_EMAIL=admin@forgemind.space
# ADMIN_PASSWORD=set-a-strong-password

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────
# Needed only for live WhatsApp send/receive. Leave unset to work on UI/API
# without making real Meta calls.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
# App Secret (Meta App → Settings → Basic). Used to verify the
# X-Hub-Signature-256 HMAC on inbound webhooks so forged payloads are rejected.
# Required for production webhook security.
META_APP_SECRET=

# ── Optional tuning (defaults shown; uncomment to override) ─────────────
# MEDIA_DIR=./media                 # where downloaded chat media is stored
# MEDIA_TRANSCODE_AUDIO=true        # ffmpeg Ogg→MP3 fallback for Safari
# MEDIA_QUEUE_CONCURRENCY=2
# MEDIA_QUEUE_ATTEMPTS=3
# MEDIA_QUEUE_BACKOFF_MS=5000
# SEND_QUEUE_CONCURRENCY=10
# SEND_QUEUE_ATTEMPTS=3
# SEND_RATE_MAX=60                  # outbound messages …
# SEND_RATE_DURATION_MS=1000        # … per this window
# TEMPLATE_SYNC_INTERVAL_MS=14400000
