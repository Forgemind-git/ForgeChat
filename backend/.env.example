# ForgeChat backend configuration — copy to .env and fill in.
# NEVER commit your real .env. See CONTRIBUTING.md for local-dev setup.

# ── App ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────
# Primary connection string (preferred).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_SSL=false
# Password for the bundled Postgres container. docker-compose.sample.yml reads
# this via env_file to initialise the DB — it MUST match the password embedded
# in DATABASE_URL above. Change both to something strong before going live.
POSTGRES_PASSWORD=postgres
# Fallback discrete params (used only if DATABASE_URL is unset).
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_password

# ── Redis (required — BullMQ send + media-download queues) ──────────────
REDIS_URL=redis://localhost:6379

# ── Auth & encryption ──────────────────────────────────────────────────
# Long random string used to sign JWT auth tokens. Generate with:
#   openssl rand -hex 32
# In production the server refuses to start if this is missing, left at the
# placeholder below, or shorter than 32 characters.
JWT_SECRET=change-this-to-a-random-string
# Passphrase for encrypting stored Meta access tokens (AES-256-GCM; the value
# is SHA-256'd to derive a 32-byte key). Falls back to JWT_SECRET if unset in
# dev, but production requires a dedicated value (same rules as JWT_SECRET).
# Generate a DIFFERENT one with: openssl rand -hex 32
FORGECRM_ENCRYPTION_KEY=change-this-to-another-random-string

# First-run admin seed (only used when the users table is empty).
# In production ADMIN_PASSWORD is REQUIRED. In dev, if it is unset a random
# password is generated and written to backend/.admin-password (chmod 600) on
# first boot — never printed to the logs. Set it explicitly for a known login.
ADMIN_EMAIL=admin@forgemind.space
# ADMIN_PASSWORD=set-a-strong-password

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── LLM provider fallbacks (used when an agent doesn't have its own key) ──
# Each AI Agent can BYOK its own provider key (per-agent override, stored
# AES-256-GCM encrypted). When the per-agent key is blank, the engine falls
# back to whichever of these matches the agent's provider. Leave both unset
# to require BYOK on every agent.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional tuning for the agent inference queue.
# AGENT_QUEUE_CONCURRENCY=4
# AGENT_QUEUE_ATTEMPTS=2

# ── Google OAuth (Sheets in v1; Gmail + Calendar in a later release) ───
# Create an OAuth 2.0 Client (Web application) in Google Cloud Console
# (https://console.cloud.google.com/apis/credentials), enable the Google
# Sheets + Google Drive APIs for the project, and authorize the redirect
# URI below. Leave unset to disable the Google Integrations tab entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what's configured in the Google Cloud Console. In
# local dev with the Vite frontend, browsers hit the backend through the
# Vite proxy, so use a URL the backend can serve directly:
#   Dev:  http://localhost:3001/api/google-integrations/callback
#   Prod: https://your-domain/api/google-integrations/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google-integrations/callback

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────
# Needed only for live WhatsApp send/receive. Leave unset to work on UI/API
# without making real Meta calls.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ── Optional tuning (defaults shown; uncomment to override) ─────────────
# MEDIA_DIR=./media                 # where downloaded chat media is stored
# MEDIA_TRANSCODE_AUDIO=true        # ffmpeg Ogg→MP3 fallback for Safari
# MEDIA_QUEUE_CONCURRENCY=2
# MEDIA_QUEUE_ATTEMPTS=3
# MEDIA_QUEUE_BACKOFF_MS=5000
# SEND_QUEUE_CONCURRENCY=10
# SEND_QUEUE_ATTEMPTS=3
# SEND_RATE_MAX=60                  # outbound messages …
# SEND_RATE_DURATION_MS=1000        # … per this window
# TEMPLATE_SYNC_INTERVAL_MS=14400000
